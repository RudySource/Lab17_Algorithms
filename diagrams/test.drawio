        <mxCell id="7" value="Console.Write(&quot;Введите процент чаевых (например, 10): &quot;)&#10;double tipPercent = Convert.ToDouble(Console.ReadLine())" style="shape=parallelogram;whiteSpace=wrap;html=1;" vertex="1" parent="1">
